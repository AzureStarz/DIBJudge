# Copy to a private file such as .env or cluster_env.sh; do not commit real paths/secrets.

# Repository root. Defaults to the parent directory of scripts/.
# export DIBJUDGE_ROOT=/path/to/DIBJudge

# Optional Conda/bootstrap configuration for shell and SLURM scripts.
# export DIBJUDGE_CONDA_INIT=/path/to/miniconda3/etc/profile.d/conda.sh
# export DIBJUDGE_CONDA_ENV=dibjudge
# export DIBJUDGE_ENV_FILE=/path/to/private_proxy_or_cluster_env.sh
# export DIBJUDGE_MODULES="cuda/12 gcc/11"

# Data/model locations.
